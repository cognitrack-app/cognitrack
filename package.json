{
  "name": "cognitrack",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev:mobile": "pnpm --filter @cognitrack/mobile start",
    "dev:desktop": "pnpm --filter @cognitrack/desktop start",
    "dev:functions": "pnpm --filter cognitrack-functions build:watch",
    "build:shared": "pnpm --filter @cognitrack/shared build",
    "build:functions": "pnpm build:shared && pnpm --filter cognitrack-functions build",
    "build:all": "pnpm build:shared && pnpm -r --filter=!@cognitrack/shared build",
    "emulators": "firebase emulators:start",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:all": "firebase deploy"
  },
  "dependencies": {
    "vitest": "^4.1.4"
  }
}
