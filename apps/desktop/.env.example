# ── Firebase ────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Google OAuth (Desktop app credentials) ───────────────────────────
#
# SETUP STEPS:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Click “Create Credentials” → “OAuth client ID”
#   3. Application type: “Desktop app”  <── IMPORTANT: NOT “Web application”
#   4. Name: “CogniTrack Desktop”
#   5. Click “Create” — copy the Client ID and Client Secret below.
#   6. In “Authorised redirect URIs” add:  cognitrack://auth
#   7. In Firebase Console → Authentication → Sign-in method,
#      make sure “Google” is enabled.
#
# These credentials are used ONLY in the main process (googleOAuth.ts).
# They are NEVER injected into the renderer via vite.config.ts define{}.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
